{
  "name": "@vidavidorra/logo",
  "version": "2.0.5",
  "private": true,
  "description": "Logo for the vidavidorra organisation",
  "homepage": "https://github.com/vidavidorra/logo#readme",
  "bugs": {
    "url": "https://github.com/vidavidorra/logo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vidavidorra/logo.git"
  },
  "license": "GPL-3.0-or-later",
  "author": "Jeroen de Bruijn",
  "type": "module",
  "exports": "./dist/index.js",
  "files": [
    "./dist/**/!(*.test).{js,d.ts,cjs}"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"**/*.{vue,css,less,scss,html,htm,json,md,markdown,yml,yaml}\" --log-level warn",
    "format:check": "prettier --check \"**/*.{vue,css,less,scss,html,htm,json,md,markdown,yml,yaml}\" --log-level warn",
    "lint": "npm run format:check && eslint",
    "lint:fix": "npm run format && eslint --fix",
    "prepare": "husky .github/husky",
    "start": "npm run build && node ./dist/index.js",
    "test": ""
  },
  "commitlint": {
    "extends": [
      "@vidavidorra"
    ]
  },
  "prettier": "@vidavidorra/prettier-config",
  "release": {
    "extends": "@vidavidorra/semantic-release-config"
  },
  "dependencies": {
    "@prettier/plugin-xml": "3.4.2",
    "prettier": "3.8.5",
    "sharp": "0.35.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@types/node": "25.9.4",
    "@vidavidorra/commitlint-config": "8.0.2",
    "@vidavidorra/eslint-config": "1.0.4",
    "@vidavidorra/prettier-config": "1.0.7",
    "@vidavidorra/semantic-release-config": "2.0.2",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "semantic-release": "25.0.5",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
